# Frontend URLs
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
FIREBASE_ADMIN_SDK_KEY=path/to/serviceAccountKey.json

# Database
DATABASE_URL=postgresql://videoadmin:videoadmin123@localhost:5432/idea_video_maker

# Redis Cache & Job Queue
REDIS_URL=redis://localhost:6379/0

# OpenAI API (Script Generation)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4

# ElevenLabs API (Text-to-Speech Voiceover)
ELEVEN_LABS_API_KEY=your_elevenlabs_api_key
ELEVEN_LABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Stability AI API (Video Generation - Optional)
STABILITY_API_KEY=your_stability_api_key

# Unsplash API (Stock Photos)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Pexels API (Stock Videos)
PEXELS_API_KEY=your_pexels_api_key

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Server Configuration
ENVIRONMENT=development
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# File Upload Configuration
MAX_VIDEO_DURATION=600
MAX_FILE_SIZE=1000000000
MAX_UPLOAD_SIZE=104857600

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# Feature Flags
FEATURE_AI_AVATAR=false
FEATURE_BATCH_GENERATION=false
FEATURE_SOCIAL_SHARING=false
FEATURE_PREMIUM_TIER=false
